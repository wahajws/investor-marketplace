{
  "installCommand": "npm install",
  "buildCommand": "if [ -d apps/web ]; then npm --prefix apps/web run build; else npm run build; fi",
  "outputDirectory": "apps/web/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
