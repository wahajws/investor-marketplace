NODE_ENV=production
PORT=4000
API_PREFIX=api/v1
RATE_LIMIT_PER_MINUTE=120

DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/vc_platform
REDIS_HOST=HOST
REDIS_PORT=6379
REDIS_PASSWORD=

APP_FRONTEND_URL=https://your-domain.com
STORAGE_PATH=/var/www/investor-marketplace/storage

JWT_ACCESS_SECRET=replace_with_at_least_32_random_characters
JWT_REFRESH_SECRET=replace_with_at_least_32_random_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

ALIBABA_API_KEY=
ALIBABA_API_BASE_URL=https://dashscope-intl.aliyuncs.com
ALIBABA_MODEL=qwen-plus

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

VITE_API_BASE_URL=https://your-domain.com/api/v1
VITE_APP_NAME=VC Intelligence
VITE_APP_REGION=Malaysia and Southeast Asia
